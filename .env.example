# mcploitable does not require any real credentials to run.
#
# This file exists only to document that nothing here needs a live value —
# no server reads .env at runtime; it's a leftover of the original author's
# local tooling, not a dependency of any vulnerable server. Copy this to
# .env only if some other local tool you use expects the file to exist;
# leave every value empty/placeholder.

GITHUB_TOKEN=
