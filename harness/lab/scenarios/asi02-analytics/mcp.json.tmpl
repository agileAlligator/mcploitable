{
  "mcpServers": {
    "analytics-bi": {
      "type": "stdio",
      "command": "docker",
      "args": [
        "compose", "-f", "${REPO}/docker-compose.yml", "run", "--rm", "-T",
        "-v", "${STATE_DIR}:/data",
        "-e", "LAB_LEVEL=${LAB_LEVEL}",
        "-e", "ASI02_STORE=/data/store.json",
        "-e", "ASI02_SCORE_LOG=/data/score.log",
        "analytics"
      ]
    }
  }
}
