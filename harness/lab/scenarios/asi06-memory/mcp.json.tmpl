{
  "mcpServers": {
    "memo-assistant": {
      "type": "stdio",
      "command": "docker",
      "args": [
        "compose", "-f", "${REPO}/docker-compose.yml", "run", "--rm", "-T",
        "-v", "${STATE_DIR}:/data",
        "-v", "${SINK_DIR}:/sink",
        "-e", "LAB_LEVEL=${LAB_LEVEL}",
        "-e", "ASI06_STORE=/data/memory.json",
        "-e", "ASI06_SCORE_LOG=/data/score.log",
        "-e", "ASI06_SINK=/sink/outbox.log",
        "memory"
      ]
    }
  }
}
