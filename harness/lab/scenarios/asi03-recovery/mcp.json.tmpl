{
  "mcpServers": {
    "account-recovery": {
      "type": "stdio",
      "command": "docker",
      "args": [
        "compose", "-f", "${REPO}/docker-compose.yml", "run", "--rm", "-T",
        "-v", "${STATE_DIR}:/data",
        "-v", "${SINK_DIR}:/sink",
        "-e", "LAB_LEVEL=${LAB_LEVEL}",
        "-e", "ASI03_STORE=/data/asi03_store.json",
        "-e", "ASI03_MAILBOX_DIR=/sink",
        "-e", "LAB_SCORE_LOG=/data/score.log",
        "-e", "ASI03_SCORE_LOG=/data/score.log",
        "recovery"
      ]
    }
  }
}
